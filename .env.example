# Credenciales del sitio
GOLPREDICTOR_USER=tu_usuario
GOLPREDICTOR_PASS=tu_contraseña

# API key que protege el endpoint (genera una larga y aleatoria)
API_KEY=cambiame-por-un-string-largo-y-aleatorio

# Nombre de la polla a abrir (texto del link en la tabla de grupos)
POLLA_NAME=Polla NowBit

# Opcional
PORT=3000
HEADLESS=true
SCRAPE_TIMEOUT_MS=45000
